# Compose project
COMPOSE_PROJECT_NAME=smarthire

# Registry images
BACKEND_IMAGE=ghcr.io/your-org-or-user/smarthire-backend
FRONTEND_IMAGE=ghcr.io/your-org-or-user/smarthire-frontend
IMAGE_TAG=latest

# Database and auth
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=smarthire
DB_USERNAME=root
DB_PASSWORD=change-me-root-password
JWT_SECRET=change-me-jwt-secret-at-least-32-bytes-long

# Messaging and cache
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# Port mapping
MYSQL_PORT=3306
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
BACKEND_PORT=8080
FRONTEND_PORT=5173

# Flyway and scheduler
SPRING_FLYWAY_ENABLED=true
SPRING_FLYWAY_BASELINE_ON_MIGRATE=false
SPRING_FLYWAY_BASELINE_VERSION=3
JWT_ACCESS_TOKEN_EXPIRATION_SECONDS=86400
APP_JOBS_EXPIRATION_ENABLED=true
APP_JOBS_EXPIRATION_CRON=0 */5 * * * *
APP_JOBS_EXPIRATION_ZONE=Asia/Shanghai
APP_INTERVIEWS_REMINDER_ENABLED=true
APP_INTERVIEWS_REMINDER_CRON=0 */10 * * * *
APP_INTERVIEWS_REMINDER_ZONE=Asia/Shanghai
APP_INTERVIEWS_REMINDER_UPCOMING_WINDOW_HOURS=24
APP_INTERVIEWS_REMINDER_STARTING_SOON_WINDOW_MINUTES=60
