              ]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/notifications?page=1&size={{pageSize}}",
            "description": "Lists notifications and stores the first `notificationId`."
          }
        },
        {
          "name": "Unread Notification Count",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
