{
  "info": {
    "_postman_id": "41c160ec-3938-470b-ae1f-1f276ef95ed4",
    "name": "SmartHire",
    "description": "SmartHire local API collection. Import together with `SmartHire.local.postman_environment.json` to run the candidate, HR, and admin workflows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/health",
            "description": "Verify the backend is up before running the workflow."
          }
        },
        {
          "name": "List Jobs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/jobs?page=1&size={{pageSize}}&status=OPEN",
            "description": "Public job listing with basic pagination."
          }
        },
        {
          "name": "Get Job Detail",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/jobs/{{jobId}}",
            "description": "Fetch one job by `jobId`."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Candidate",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{newCandidateEmail}}\",\n  \"password\": \"{{newCandidatePassword}}\",\n  \"fullName\": \"{{newCandidateName}}\",\n  \"phone\": \"{{newCandidatePhone}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/auth/register",
            "description": "Optional request for creating a fresh candidate account."
          }
        },
        {
          "name": "Candidate Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json && json.data && json.data.accessToken) {",
                  "    pm.environment.set('candidateToken', json.data.accessToken);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{candidateEmail}}\",\n  \"password\": \"{{candidatePassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Logs in the seeded candidate and saves `candidateToken`."
          }
        },
