        {
          "name": "List Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  const records = (((json || {}).data || {}).records) || [];",
                  "  const managedUser = records.find(item => !(item.roles || []).includes('ADMIN'));",
                  "  if (managedUser && managedUser.id) {",
                  "    pm.environment.set('userId', String(managedUser.id));",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/admin/users?page=1&size={{pageSize}}",
            "description": "Lists users and stores the first non-admin `userId`."
          }
        },
